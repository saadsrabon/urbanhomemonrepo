# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/urban_home_security?schema=public

# Server
PORT=4000
NODE_ENV=development
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
CORS_ORIGIN=http://localhost:3000
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# Seed Super Admin
SEED_ADMIN_EMAIL=admin@urbanhomeandsecurity.com
SEED_ADMIN_PASSWORD=Admin@123456
SEED_ADMIN_NAME=Super Admin

# SMTP (optional for dev)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@urbanhomeandsecurity.com
ADMIN_NOTIFY_EMAIL=info@urbanhomeandsecurity.com

# Web
NEXT_PUBLIC_API_URL=http://localhost:4000/api
