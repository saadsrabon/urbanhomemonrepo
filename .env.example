# Database (used by docker-compose for postgres + api)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=urban_home_security

# Docker Compose (api container talks to postgres service name)
DATABASE_URL=postgresql://postgres:change-me-strong-password@postgres:5432/urban_home_security?schema=public

# Local dev (API via `npm run dev`, Postgres via docker-compose.dev.yml on host port 5433):
#   docker compose -f docker-compose.yml -f docker-compose.dev.yml up postgres -d
# Put this in server/.env (or root .env if you run Prisma from repo root):
# DATABASE_URL=postgresql://postgres:postgres@localhost:5433/urban_home_security?schema=public
# POSTGRES_PASSWORD=postgres

# Server
PORT=4000
NODE_ENV=production
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
CORS_ORIGIN=https://your-domain.com
UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE=5242880

# Seed Super Admin (run db:seed once after first deploy)
SEED_ADMIN_EMAIL=admin@urbanhomeandsecurity.com
SEED_ADMIN_PASSWORD=Admin@123456
SEED_ADMIN_NAME=Super Admin

# SMTP (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@urbanhomeandsecurity.com
ADMIN_NOTIFY_EMAIL=info@urbanhomeandsecurity.com

# Web — use /api when nginx serves both frontend and API on the same domain
NEXT_PUBLIC_API_URL=/api

# Public site URL for SEO (canonical, OG, sitemap). Set to your production domain.
NEXT_PUBLIC_SITE_URL=https://your-domain.com
